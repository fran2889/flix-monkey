# Integration Test Credentials
# Populate these values for running real-API integration tests
OMDB_API_KEY=your_omdb_key_here
XMDB_API_KEY=your_xmdb_key_here

# Chrome integration tests
# Uses Playwright's built-in Chromium with a workspace-local profile directory.
# On first run, manually log into Netflix in the test browser.
NETFLIX_PROFILE_NAME=Your Netflix Profile
CHROME_INTEGRATION_HEADLESS=false
CHROME_INTEGRATION_KEEP_OPEN=false
CHROME_INTEGRATION_TIMEOUT_MS=30000
