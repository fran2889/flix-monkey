{
    "name": "FlixMonkey",
    "version": "1.1.1",
    "description": "See IMDb, Metacritic, and Rotten Tomatoes ratings while browsing Netflix.",
    "author": "fran",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/fran2889/flix-monkey",
    "type": "module",
    "scripts": {
        "prepare": "husky",
        "format": "prettier --write \"{src,tests}/**/*.{js,cjs}\" \"src/**/*.html\" \"*.{json,md,yml,html}\"",
        "format:check": "prettier --check \"{src,tests}/**/*.{js,cjs}\" \"src/**/*.html\" \"*.{json,md,yml,html}\"",
        "lint": "eslint \"{src,tests}/**/*.{js,cjs}\" \"scripts/**/*.js\" \"*.config.{js,cjs}\"",
        "lint:fix": "eslint --fix \"{src,tests}/**/*.{js,cjs}\" \"scripts/**/*.js\" \"*.config.{js,cjs}\"",
        "build:userscript": "rollup -c --environment TARGET:userscript",
        "build:firefox": "rollup -c --environment TARGET:firefox && node scripts/package.js",
        "build:chrome": "rollup -c --environment TARGET:chrome && node scripts/package.js",
        "build": "rollup -c && node scripts/package.js",
        "package:source": "git archive --format=zip --output dist/FlixMonkey-v$npm_package_version-source.zip HEAD",
        "dev": "rollup -cw",
        "test": "vitest run tests/unit tests/ui",
        "test:coverage": "vitest run tests/unit tests/ui --coverage",
        "test:unit": "vitest run tests/unit",
        "test:ui": "vitest run tests/ui",
        "test:integration": "vitest run -c vitest.integration.config.js",
        "audit": "npm audit --audit-level=high",
        "clean": "npx rimraf dist coverage"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-commonjs": "^29.0.0",
        "@rollup/plugin-node-resolve": "^16.0.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@vitest/coverage-v8": "^4.1.9",
        "archiver": "^8.0.0",
        "chrome-webstore-upload-cli": "^4.0.1",
        "dotenv": "^17.4.2",
        "eslint": "^10.1.0",
        "eslint-plugin-headers": "^1.3.4",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.7",
        "msw": "^2.14.2",
        "prettier": "^3.8.4",
        "rollup": "^4.61.1",
        "sharp": "^0.35.1",
        "vitest": "^4.1.5",
        "web-ext": "^10.4.0",
        "webextension-polyfill": "^0.12.0"
    },
    "engines": {
        "node": ">= 24"
    },
    "lint-staged": {
        "**/*.{js,cjs,ts,jsx,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "**/*.{json,md,yml,html}": [
            "prettier --write"
        ]
    }
}
